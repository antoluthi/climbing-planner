{
  "headers": [
    {
      "source": "/api/caldav/(.*)",
      "headers": [
        { "key": "DAV", "value": "1, 3, calendar-access" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/caldav/:slug+/",
      "destination": "/api/caldav/:slug+"
    }
  ],
  "redirects": [
    {
      "source": "/.well-known/caldav",
      "destination": "/profil",
      "permanent": false
    },
    {
      "source": "/.well-known/carddav",
      "destination": "/profil",
      "permanent": false
    }
  ]
}
